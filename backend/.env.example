# Copy this file to .env and fill in your values
# ---------------------------------------------------

# DATABASE — Neon Postgres (single DB for dev + prod)
# Get connection string from neon.tech → your project → Connection Details
# Format: postgresql+asyncpg://<user>:<password>@<host>/<dbname>?sslmode=require
MARKDROP_DATABASE_URL=postgresql+asyncpg://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require

# REDIS — Redis running on localhost (same machine)
# Local dev: brew install redis && brew services start redis
# EC2 prod:  sudo apt install redis-server && sudo systemctl enable redis-server
MARKDROP_REDIS_URL=redis://localhost:6379

# DEBUG — set to false on EC2
MARKDROP_DEBUG=true

# CORS — production: set to https://markdrop.in
MARKDROP_CORS_ORIGINS=["http://localhost:3000"]
