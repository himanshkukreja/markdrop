# Copy this file to .env and fill in your values
# ---------------------------------------------------

# MONGODB — paste your connection string here
# MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MARKDROP_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MARKDROP_MONGODB_DB=markdrop

# REDIS — Redis running on localhost (same machine)
# Local dev: brew install redis && brew services start redis
# EC2 prod:  sudo apt install redis-server && sudo systemctl enable redis-server
MARKDROP_REDIS_URL=redis://localhost:6379

# DEBUG — set to false on EC2
MARKDROP_DEBUG=true

# CORS — production: set to https://markdrop.in
MARKDROP_CORS_ORIGINS=["http://localhost:3000"]
